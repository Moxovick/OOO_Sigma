{"id":24,"date":"2017-08-13T15:37:55","date_gmt":"2017-08-13T12:37:55","guid":{"rendered":"http:\/\/sigma-profi.org\/?page_id=24"},"modified":"2025-03-24T14:30:02","modified_gmt":"2025-03-24T11:30:02","slug":"o-kompanii","status":"publish","type":"page","link":"https:\/\/sigma-profi.org\/o-kompanii\/","title":{"rendered":"\u041e \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438"},"content":{"rendered":"<section class=\"kc-elm kc-css-304077 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-121967 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div class=\"kc-elm kc-css-496404 kc_text_block\"><\/p>\n<p><strong><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full\" src=\"http:\/\/sigma-profi.org\/wp-content\/uploads\/2017\/08\/o-kompanii.jpg\" alt=\"\" width=\"870\" height=\"400\"><\/strong><\/p>\n<p><strong>\u0413\u0440\u0443\u043f\u043f\u0430 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0439 \u043f\u043e \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044e \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb<\/strong> \u0431\u044b\u043b\u0430 \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0430 \u0432 \u0433. \u041c\u043e\u0441\u043a\u0432\u0435 \u0431\u043e\u043b\u0435\u0435 20 \u043b\u0435\u0442 \u043d\u0430\u0437\u0430\u0434 (\u0432 2001 \u0433\u043e\u0434\u0443). \u0427\u0430\u0441\u0442\u043d\u043e\u0435 \u043e\u0445\u0440\u0430\u043d\u043d\u043e\u0435 \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u044f\u0442\u0438\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u0438 \u043b\u0438\u0446\u0435\u043d\u0437\u0438\u0438 \u21162597. \u041d\u0430 \u0431\u0430\u0437\u0435 \u0427\u041e\u041f\u0430 \u043e\u0442\u043a\u0440\u044b\u0442 \u0438 \u0443\u0441\u043f\u0435\u0448\u043d\u043e \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u0426\u0435\u043d\u0442\u0440 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0439 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438 \u043e\u0445\u0440\u0430\u043d\u043d\u0438\u043a\u043e\u0432.<\/p>\n<h2><strong>\u041d\u0430\u0448\u0430 \u0437\u0430\u0434\u0430\u0447\u0430<\/strong><\/h2>\n<p>\u0421\u0432\u043e\u0435\u0439 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u0439 \u0437\u0430\u0434\u0430\u0447\u0435\u0439 \u043e\u0445\u0440\u0430\u043d\u043d\u0430\u044f \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u044f \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u0441\u0447\u0438\u0442\u0430\u0435\u0442 \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u043a\u043b\u0438\u0435\u043d\u0442\u0430\u043c \u0441\u0435\u0440\u0432\u0438\u0441\u0430 \u0432\u044b\u0441\u043e\u0447\u0430\u0439\u0448\u0435\u0433\u043e \u0443\u0440\u043e\u0432\u043d\u044f. \u041c\u044b \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u0431\u044b\u0441\u0442\u0440\u043e \u0432\u043d\u0435\u0434\u0440\u044f\u0435\u043c \u043d\u043e\u0432\u044b\u0435 \u043f\u0440\u0438\u0435\u043c\u044b \u0438 \u043c\u0435\u0442\u043e\u0434\u044b \u0440\u0430\u0431\u043e\u0442\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f \u0432 \u043c\u0438\u0440\u0435, \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044e \u0437\u043d\u0430\u044e\u0442 \u043a\u0430\u043a \u043d\u0430\u0434\u0435\u0436\u043d\u043e\u0433\u043e \u0438 \u0432\u044b\u0441\u043e\u043a\u043e\u043a\u0432\u0430\u043b\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u043f\u0430\u0440\u0442\u043d\u0435\u0440\u0430 \u0432 \u0434\u0435\u043b\u0435 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438. \u0414\u043b\u044f \u00ab\u0421\u0438\u0433\u043c\u044b-\u041f\u0440\u043e\u0444\u0438\u00bb \u043c\u043d\u0435\u043d\u0438\u044f \u0430\u0431\u0441\u043e\u043b\u044e\u0442\u043d\u043e \u0432\u0441\u0435\u0445 \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432 \u0438 \u043a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0442\u043e\u0432 \u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f \u0433\u043b\u0430\u0432\u043d\u044b\u043c\u0438 \u043a\u0440\u0438\u0442\u0435\u0440\u0438\u044f\u043c\u0438 \u043e\u0446\u0435\u043d\u043a\u0438 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u0438\u0437\u043c\u0430.<\/p>\n<h2><strong>\u041d\u0430\u0448\u0430 \u0446\u0435\u043b\u044c<\/strong><\/h2>\n<p>\u0426\u0435\u043b\u044c \u043e\u0445\u0440\u0430\u043d\u043d\u043e\u0433\u043e \u0445\u043e\u043b\u0434\u0438\u043d\u0433\u0430 \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u2013 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0430\u044f \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u043f\u0440\u0438 \u043c\u0438\u043d\u0438\u043c\u0438\u0437\u0430\u0446\u0438\u0438 \u0438\u0437\u0434\u0435\u0440\u0436\u0435\u043a. \u041f\u0440\u0435\u043a\u0440\u0430\u0441\u043d\u043e \u043f\u043e\u043d\u0438\u043c\u0430\u044f, \u0447\u0442\u043e \u0432\u043e\u043f\u0440\u043e\u0441\u044b \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f \u043d\u0435\u043e\u0442\u044a\u0435\u043c\u043b\u0435\u043c\u043e\u0439 \u0447\u0430\u0441\u0442\u044c\u044e \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0433\u043e \u0431\u0438\u0437\u043d\u0435\u0441\u0430 \u0438 \u0435\u0433\u043e \u0440\u0435\u0430\u043a\u0446\u0438\u0435\u0439 \u043d\u0430 \u0432\u044b\u0437\u043e\u0432\u044b \u0441\u0435\u0433\u043e\u0434\u043d\u044f\u0448\u043d\u0435\u0433\u043e \u0434\u043d\u044f, \u043c\u044b \u043d\u0435 \u0434\u043e\u043f\u0443\u0441\u043a\u0430\u0435\u043c \u043f\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043d\u0438\u044f \u00ab\u0443\u0434\u043e\u0431\u043d\u043e\u0433\u043e \u0431\u0440\u043e\u043d\u0435\u0436\u0438\u043b\u0435\u0442\u0430\u00bb \u0432 \u00ab\u043d\u0435\u043f\u043e\u0434\u044a\u0435\u043c\u043d\u044b\u0435 \u043b\u0430\u0442\u044b\u00bb. \u041d\u0430\u0448\u0430 \u0444\u0438\u0440\u043c\u0430 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442 \u0433\u0438\u0431\u043a\u0438\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u044f, \u0441\u043f\u043e\u0441\u043e\u0431\u043d\u044b\u0435 \u0443\u0434\u043e\u0432\u043b\u0435\u0442\u0432\u043e\u0440\u0438\u0442\u044c \u0441\u0430\u043c\u044b\u0445 \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u0438 \u0432\u0437\u044b\u0441\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u043e\u0432.<\/p>\n<p><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full\" src=\"http:\/\/sigma-profi.org\/wp-content\/uploads\/2018\/11\/podgotovka-78.jpg\" alt=\"\u0421\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0438 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u0432 \u0420\u043e\u0441\u0441\u0438\u0439\u0441\u043a\u043e\u043c \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0441\u043f\u0435\u0446\u043d\u0430\u0437\u0430 \u0432 \u0413\u0443\u0434\u0435\u0440\u043c\u0435\u0441\u0435\" width=\"1280\" height=\"720\"><\/p>\n<h2><strong>\u041d\u0430\u0448\u0438 \u043a\u043b\u0438\u0435\u043d\u0442\u044b<\/strong><\/h2>\n<p>\u0421\u043f\u0435\u0446\u0438\u0444\u0438\u043a\u0430 \u043e\u0445\u0440\u0430\u043d\u043d\u043e\u0433\u043e \u0431\u0438\u0437\u043d\u0435\u0441\u0430 \u0442\u0430\u043a\u043e\u0432\u0430, \u0447\u0442\u043e \u043f\u043e\u044f\u0432\u043b\u0435\u043d\u0438\u0435 \u043d\u043e\u0432\u044b\u0445 \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432 \u0432 \u043f\u0435\u0440\u0432\u0443\u044e \u043e\u0447\u0435\u0440\u0435\u0434\u044c \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u044f\u043c\u0438 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0445, \u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e, \u0432\u043e\u043f\u0440\u043e\u0441 \u0440\u0435\u043f\u0443\u0442\u0430\u0446\u0438\u0438 \u0434\u043b\u044f \u00ab\u0421\u0438\u0433\u043c\u044b-\u041f\u0440\u043e\u0444\u0438\u00bb \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u043c. \u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0440\u0438 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0438 \u0438 \u043f\u0440\u0435\u0443\u0441\u043f\u0435\u0432\u0430\u043d\u0438\u0438 \u043d\u0430\u0448\u0438\u0445 \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432: \u043c\u044b \u0430\u0441\u0441\u043e\u0446\u0438\u0438\u0440\u0443\u0435\u043c \u0441\u0435\u0431\u044f \u0441 \u043d\u0438\u043c\u0438, \u0438\u0445 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u0441\u0442\u0430\u043d\u043e\u0432\u044f\u0442\u0441\u044f \u043d\u0430\u0448\u0438\u043c\u0438, \u0430 \u0432 \u0438\u0445 \u0434\u043e\u0441\u0442\u0438\u0436\u0435\u043d\u0438\u044f\u0445 \u0435\u0441\u0442\u044c \u0438 \u043d\u0430\u0448\u0430 \u0437\u0430\u0441\u043b\u0443\u0433\u0430.<\/p>\n<p>\u0421\u043f\u0438\u0441\u043e\u043a \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e \u0440\u0430\u0441\u0442\u0435\u0442:<\/p>\n<ul>\n<li>\u043e\u0442\u0435\u043b\u044c \u00ab\u0411\u0430\u043b\u0447\u0443\u0433-\u041a\u0435\u043c\u043f\u0438\u043d\u0441\u043a\u0438\u00bb,<\/li>\n<li>\u043e\u0442\u0435\u043b\u044c \u00ab\u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442\u00bb,<\/li>\n<li>\u043e\u0442\u0435\u043b\u044c \u00abFourSeasons\u00bb,<\/li>\n<li>\u043e\u0442\u0435\u043b\u044c \u00ab\u041c\u0420\u0418\u042f\u00bb,<\/li>\n<li>\u041e\u0410\u041e \u00ab\u0410\u041a \u00ab\u0422\u0440\u0430\u043d\u0441\u043d\u0435\u0444\u0442\u044c\u00bb,<\/li>\n<li>\u0413\u041a \u00ab\u0422\u041c\u041a\u00bb,<\/li>\n<li>\u041f\u0410\u041e \u00ab\u0421\u0438\u0431\u0443\u0440 \u0425\u043e\u043b\u0434\u0438\u043d\u0433\u00bb,<\/li>\n<li>\u0410\u041d\u041e \u0412\u041e &#171;\u0426\u0435\u043d\u0442\u0440\u0430\u043b\u044c\u043d\u044b\u0439 \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442&#187;<\/li>\n<\/ul>\n<p><em style=\"color: #ee000e;\">\u0438 \u043c\u043d\u043e\u0433\u0438\u0435 \u0434\u0440\u0443\u0433\u0438\u0435<\/em>.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><\/div><\/section>\n","protected":false},"excerpt":{"rendered":"","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"footnotes":""},"class_list":["post-24","page","type-page","status-publish","hentry"],"yoast_head":"<!-- This site is optimized with the Yoast SEO plugin v24.1 - https:\/\/yoast.com\/wordpress\/plugins\/seo\/ -->\n<title>\u041e \u0433\u0440\u0443\u043f\u043f\u0435 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0439 \u043f\u043e \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044e \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb<\/title>\n<meta name=\"description\" content=\"\u0427\u0430\u0441\u0442\u043d\u043e\u0435 \u043e\u0445\u0440\u0430\u043d\u043d\u043e\u0435 \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u044f\u0442\u0438\u0435 \u043e\u0441\u043d\u043e\u043