{"id":3685,"date":"2019-04-01T16:32:22","date_gmt":"2019-04-01T13:32:22","guid":{"rendered":"http:\/\/sigma-profi.org\/?page_id=3685"},"modified":"2025-04-01T16:05:59","modified_gmt":"2025-04-01T13:05:59","slug":"podgotovka-sotrudnikov","status":"publish","type":"page","link":"https:\/\/sigma-profi.org\/podgotovka-sotrudnikov\/","title":{"rendered":"\u041f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb"},"content":{"rendered":"<p><section class=\"kc-elm kc-css-137366 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-491209 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div class=\"kc-elm kc-css-674542 kc_text_block\"><\/p>\n<p>\n<img loading=\"lazy\" decoding=\"async\" class=\"aligncenter wp-image-3738\" src=\"http:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/04\/img_0924.jpg\" alt=\"\" width=\"870\" height=\"580\" data-headline=\"IMG_0924\" srcset=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/04\/img_0924.jpg 726w, https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/04\/img_0924-300x200.jpg 300w\" sizes=\"auto, (max-width: 870px) 100vw, 870px\" \/><\/p>\n<p>\n<\/div><\/div><\/div><\/div><\/div><\/section><section class=\"kc-elm kc-css-574969 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-19747 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div class=\"kc-elm kc-css-761245\" style=\"height: 25px; clear: both; width:100%;\"><\/div><div class=\"kc-elm kc-css-48285 kc_text_block\"><\/p>\n<p>\n\u041d\u0430\u0448\u0430 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u044f \u043e\u0447\u0435\u043d\u044c \u0441\u0435\u0440\u044c\u0435\u0437\u043d\u043e \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u043a \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0435 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432. \u041f\u0440\u0438 \u043f\u0440\u0438\u0435\u043c\u0435 \u043d\u0430 \u0440\u0430\u0431\u043e\u0442\u0443 \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u044b \u043d\u0430 \u0434\u043e\u043b\u0436\u043d\u043e\u0441\u0442\u044c \u0441\u0440\u0430\u0437\u0443 \u0441\u0442\u0430\u043b\u043a\u0438\u0432\u0430\u044e\u0442\u0441\u044f \u0441 \u0436\u0435\u0441\u0442\u043e\u0447\u0430\u0439\u0448\u0438\u043c \u043e\u0442\u0431\u043e\u0440\u043e\u043c. \u041a \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0430\u043c \u043f\u0440\u0435\u0434\u044a\u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f \u0432\u044b\u0441\u043e\u043a\u0438\u0435 \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f: \u043f\u0440\u0435\u043a\u0440\u0430\u0441\u043d\u0430\u044f \u044d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0430\u044f \u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430, \u0430\u043a\u043a\u0443\u0440\u0430\u0442\u043d\u044b\u0439 \u0432\u043d\u0435\u0448\u043d\u0438\u0439 \u0432\u0438\u0434, \u0432\u044b\u0441\u043e\u043a\u0438\u0439 \u0443\u0440\u043e\u0432\u0435\u043d\u044c iq. \u041d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u043c \u043e\u0445\u0440\u0430\u043d\u044b \u043e\u0431\u044a\u0435\u043a\u0442\u043e\u0432 \u043f\u043e \u043d\u0430\u0448\u0435\u0439 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0435 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0441\u044f \u043b\u0438\u0448\u044c 1 \u0438\u0437 20 \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u043e\u0432.<br \/>\u0420\u0443\u043a\u043e\u0432\u043e\u0434\u0441\u0442\u0432\u043e \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u0441\u043e\u0432\u043c\u0435\u0441\u0442\u043d\u043e \u0441 \u043d\u0430\u0448\u0438\u043c\u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u043c\u0438 \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0442\u043e\u0440\u0430\u043c\u0438, \u043c\u0435\u0434\u0438\u043a\u0430\u043c\u0438, \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0435\u043d\u043d\u044b\u043c\u0438 \u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\u043d\u0442\u0430\u043c\u0438, \u0438 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043b\u044f\u043c\u0438 \u041c\u0427\u0421 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0438 \u0441\u0432\u043e\u0438 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 \u043a\u0443\u0440\u0441\u044b \u043e\u0442\u0431\u043e\u0440\u0430 \u0438 \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u0438\u044f \u043a\u0432\u0430\u043b\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438 \u0434\u043b\u044f \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u043e\u0442\u0434\u0435\u043b\u0430. \u0414\u043b\u044f \u043b\u0438\u0447\u043d\u043e\u0439 \u043e\u0445\u0440\u0430\u043d\u044b, \u043e\u0442\u0434\u0435\u043b\u0430 \u0432\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u043e\u0433\u043e \u0441\u043e\u043f\u0440\u043e\u0432\u043e\u0436\u0434\u0435\u043d\u0438\u044f, \u0438 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432 \u043e\u0445\u0440\u0430\u043d\u044b \u043e\u0431\u044a\u0435\u043a\u0442\u043e\u0432 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044e\u0442 \u0441\u0432\u043e\u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438, \u0437\u0430\u0447\u0435\u0442\u044b \u0438 \u043a\u0432\u0430\u043b\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438. \u041e \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0443\u0437\u043d\u0430\u0442\u044c \u043d\u0438\u0436\u0435, \u043f\u0435\u0440\u0435\u0439\u0434\u044f \u0432 \u0436\u0435\u043b\u0430\u0435\u043c\u044b\u0439 \u043e\u0442\u0434\u0435\u043b.<\/p>\n<p>\n<\/div><div class=\"kc-elm kc-css-818303\" style=\"height: 30px; clear: both; width:100%;\"><\/div><\/div><\/div><\/div><\/div><\/section><section class=\"kc-elm kc-css-433936 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-38782 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div class=\"kc-elm kc-css-46399 kc_text_block\"><\/p>\n<hr \/>\n<p>\n<\/div><div class=\"kc-elm kc-css-256036 kc_row kc_row_inner\"><div class=\"kc-elm kc-css-347015 kc_col-sm-6 kc_column_inner kc_col-sm-6\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-451924 kc_text_block\"><\/p>\n<p><div class=\"video-container\"><iframe loading=\"lazy\" title=\"\u041e\u0433\u043d\u0435\u0432\u0430\u044f \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430 _ \u0422\u0438\u0440 _ \u041b\u0438\u0447\u043d\u0430\u044f \u043e\u0445\u0440\u0430\u043d\u0430 _ \u0422\u0435\u043b\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c\" width=\"800\" height=\"450\" src=\"https:\/\/rutube.ru\/play\/embed\/70264ab7face23301b6373c93a9255a9\" frameborder=\"0\" webkitAllowFullScreen mozallowfullscreen allowfullscreen allow=\"encrypted-media\"><\/iframe><\/div>\n<\/p>\n<p>\n<\/div><\/div><\/div><div class=\"kc-elm kc-css-262582 kc_col-sm-6 kc_column_inner kc_col-sm-6\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-688005 kc_text_block\"><\/p>\n<p><div class=\"video-container\"><iframe loading=\"lazy\" title=\"\u0411\u043e\u043a\u0441 _ \u0422\u0440\u0435\u043d\u0438\u0440\u043e\u0432\u043a\u0430 _ \u041b\u0438\u0447\u043d\u0430\u044f \u043e\u0445\u0440\u0430\u043d\u0430 _ \u0422\u0435\u043b\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044c\" width=\"800\" height=\"450\" src=\"https:\/\/rutube.ru\/play\/embed\/db9772d235bd8e5450ae65207a0d318b\" frameborder=\"0\" webkitAllowFullScreen mozallowfullscreen allowfullscreen allow=\"encrypt