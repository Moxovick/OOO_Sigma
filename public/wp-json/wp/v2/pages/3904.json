c\u043e\u043c\u0435\u043d\u0442 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u0447\u0430\u0441\u0442\u043d\u043e\u0435 \u0443\u0447\u0435\u0431\u043d\u043e\u0435 \u0437\u0430\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u0420\u043e\u0441\u0441\u0438\u0439\u0441\u043a\u043e\u0439 \u0424\u0435\u0434\u0435\u0440\u0430\u0446\u0438\u0438 \u0434\u043b\u044f \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0439 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0434\u0440\u0430\u0437\u0434\u0435\u043b\u0435\u043d\u0438\u0439. \u041e\u0441\u043d\u043e\u0432\u0430\u043d 1 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 2013 \u0433\u043e\u0434\u0430 \u043f\u043e \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044e \u0413\u043b\u0430\u0432\u044b \u0427\u0435\u0447\u0435\u043d\u0441\u043a\u043e\u0439 \u0420\u0435\u0441\u043f\u0443\u0431\u043b\u0438\u043a\u0438 \u0420\u0430\u043c\u0437\u0430\u043d\u0430 \u041a\u0430\u0434\u044b\u0440\u043e\u0432\u0430 \u0432 \u0433\u043e\u0440\u043e\u0434\u0435 \u0413\u0443\u0434\u0435\u0440\u043c\u0435\u0441 \u043a\u0430\u043a \u00ab\u041c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u044b\u0439 \u0443\u0447\u0435\u0431\u043d\u044b\u0439 \u0446\u0435\u043d\u0442\u0440 \u0441\u0438\u043b \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f\u00bb. \u041d\u0430\u0448\u0438\u043c\u0438 \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0442\u043e\u0440\u0430\u043c\u0438 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0441\u044f \u043e\u0431\u043c\u0435\u043d \u043e\u043f\u044b\u0442\u043e\u043c. \u041d\u0430\u0448\u0438 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0438 \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0442 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435 \u043f\u043e \u0442\u0430\u043a\u0438\u043c \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u0430\u043c, \u043a\u0430\u043a \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0441\u0442\u0440\u0435\u043b\u044c\u0431\u0430, \u0440\u0443\u043a\u043e\u043f\u0430\u0448\u043d\u044b\u0439 \u0431\u043e\u0439, \u0442\u0430\u043a\u0442\u0438\u043a\u0430 \u0442\u0435\u043b\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u044f, \u0432\u043e\u0435\u043d\u043d\u0430\u044f \u043c\u0435\u0434\u0438\u0446\u0438\u043d\u0430, \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430. \u0417\u0430\u043d\u044f\u0442\u0438\u044f \u0432\u0445\u043e\u0434\u044f\u0442 \u0432 \u0441\u043e\u0441\u0442\u0430\u0432 \u0435\u0436\u0435\u0433\u043e\u0434\u043d\u044b\u0445 \u0441\u0431\u043e\u0440\u043e\u0432 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u0432 \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0441\u043f\u0435\u0446\u043d\u0430\u0437\u0430.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-636192 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-615862 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-814539 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">\u0421\u0442\u0440\u0435\u043b\u043a\u043e\u0432\u044b\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441 \u00ab\u0412\u044b\u0441\u0442\u0440\u0435\u043b\u00bb <\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-739070 kc_text_block\"><\/p>\n<p>\u041b\u0443\u0447\u0448\u0435\u0435 \u043c\u0435\u0441\u0442\u043e \u043d\u0430 \u0441\u0435\u0432\u0435\u0440\u0435 \u041c\u043e\u0441\u043a\u0432\u044b \u0434\u043b\u044f \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u043e\u0432 IPSC \u0438 \u043d\u043e\u0432\u0438\u0447\u043a\u043e\u0432 \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0441\u0442\u0440\u0435\u043b\u044c\u0431\u044b. \u0421\u0442\u0440\u0435\u043b\u043a\u043e\u0432\u044b\u0439 \u043a\u043b\u0443\u0431 \u0443\u0436\u0435 \u0431\u043e\u043b\u0435\u0435 \u0442\u0440\u0435\u0445 \u043b\u0435\u0442 \u0442\u0435\u0441\u043d\u043e \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u0447\u0430\u0435\u0442 \u0441 \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0442\u043e\u0440\u0430\u043c\u0438 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb. \u0412 \u0442\u0438\u0440\u0435 \u00ab\u0412\u044b\u0441\u0442\u0440\u0435\u043b\u00bb \u043d\u0430 \u0435\u0436\u0435\u043d\u0435\u0434\u0435\u043b\u044c\u043d\u044b\u0445 \u0442\u0440\u0435\u043d\u0438\u0440\u043e\u0432\u043a\u0430\u0445 \u043f\u043e \u043e\u0433\u043d\u0435\u0432\u043e\u0439 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0435 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0438 \u043b\u0438\u0447\u043d\u043e\u0439, \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043e\u0445\u0440\u0430\u043d\u044b \u043f\u0440\u0430\u043a\u0442\u0438\u043a\u0443\u044e\u0442\u0441\u044f \u0432 \u0441\u0442\u0440\u0435\u043b\u044c\u0431\u0435 \u0438\u0437 \u0440\u0430\u0437\u043d\u044b\u0445 \u0432\u0438\u0434\u043e\u0432 \u043e\u0440\u0443\u0436\u0438\u044f.<\/p>\n<p>\n<\/div><\/div><\/div><div class=\"kc-elm kc-css-604906 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-502524 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/05\/vystrel.png\" class=\"\" alt=\"\" \/>    <\/div>\n<\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-571787 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-226101 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-996243 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/05\/mad-max.jpg\" class=\"\" alt=\"\" \/>    <\/div>\n<\/div><\/div><div class=\"kc-elm kc-css-314234 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-421640 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">MAD MAX DOJO <\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-10629 kc_text_block\"><\/p>\n<p>\u0411\u043e\u0439\u0446\u043e\u0432\u0441\u043a\u0430\u044f \u0448\u043a\u043e\u043b\u0430 \u041c\u0430\u043a\u0441\u0430 \u0414\u0435\u0434\u0438\u043a\u0430. \u0417\u0434\u0435\u0441\u044c \u043f\u0440\u0430\u043a\u0442\u0438\u043a\u0443\u0435\u0442\u0441\u044f \u0442\u0440\u0438 \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0445 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f: \u0431\u043e\u0435\u0432\u044b\u0435 \u0438\u0441\u043a\u0443\u0441\u0441\u0442\u0432\u0430, \u0431\u043e\u0435\u0432\u043e\u0439 \u0441\u043f\u043e\u0440\u0442, \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430. MAD MAX DOJO \u2013 \u044d\u0442\u043e \u0442\u0440\u0438 \u0437\u0430\u043b\u0430 \u0434\u043b\u044f \u043f\u0440\u043e\u0432\u0435\u0434\u0435\u043d\u0438\u044f \u0442\u0440\u0435\u043d\u0438\u0440\u043e\u0432\u043e\u043a \u043f\u043e\u0434 \u0440\u0443\u043a\u043e\u0432\u043e\u0434\u0441\u0442\u0432\u043e\u043c \u0447\u0435\u043c\u043f\u0438\u043e\u043d\u0430 \u043c\u0438\u0440\u0430 \u043f\u043e \u043a\u0430\u0440\u0430\u0442\u044d-\u043a\u0438\u043e\u043a\u0443\u0448\u0438\u043d\u043a\u0430\u0439, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043b\u0443\u0447\u0448\u0430\u044f \u0442\u0435\u0445\u043d\u0438\u043a\u0430, \u0442\u0430\u043a\u0442\u0438\u043a\u0430 \u0438 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044f \u0431\u043e\u044f. \u0412 \u0448\u043a\u043e\u043b\u0435 \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0442 \u0435\u0436\u0435\u043d\u0435\u0434\u0435\u043b\u044c\u043d\u044b\u0435 \u0437\u0430\u043d\u044f\u0442\u0438\u044f \u043d\u0430\u0448\u0438\u0445 \u0442\u0435\u043b\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u0435\u043b\u0435\u0439 \u043f\u043e \u0440\u0443\u043a\u043e\u043f\u0430\u0448\u043d\u043e\u043c\u0443 \u0431\u043e\u044e. \u0422\u0430\u043a\u0436\u0435 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u0432 \u043f\u0430\u0440\u0442\u043d\u0435\u0440\u0441\u0442\u0432\u0435 \u0441 \u0431\u043e\u0439\u0446\u043e\u0432\u0441\u043a\u043e\u0439 \u0448\u043a\u043e\u043b\u043e\u0439 \u041c\u0430\u043a\u0441\u0430 \u0414\u0435\u0434\u0438\u043a\u0430 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043e\u0432\u044b\u0432\u0430\u0435\u0442 \u043b\u0435\u0442\u043d\u0438\u0435 \u0441\u0431\u043e\u0440\u044b \u0434\u043b\u044f \u043c\u043e\u043b\u043e\u0434\u044b\u0445 \u043a\u0430\u0440\u0430\u0442\u0438\u0441\u0442\u043e\u0432.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-944711 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-404678 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-172441 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">\u0410\u0432\u0438\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0439 \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u0439 \u043a\u043b\u0443\u0431 \u00ab\u0410\u044d\u0440\u043e\u043a\u043b\u0430\u0441\u0441\u0438\u043a\u0430\u00bb <\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-620920 kc_text_block\"><\/p>\n<p>\u0426\u0435\u043d\u0442\u0440 \u0441\u043a\u0430\u0439\u0434\u0430\u0439\u0432\u0438\u043d\u0433\u0430 \u0432 \u0412\u0430\u0442\u0443\u043b\u0438\u043d\u043e, \u041c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u0430\u044f \u043e\u0431\u043b\u0430\u0441\u0442\u044c. \u0412 \u043a\u043b\u0443\u0431\u0435 \u043c\u043e\u0436\u043d\u043e \u0432\u044b\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u043e\u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u043f\u0440\u044b\u0436\u043a\u0438 \u0432 \u0442\u0430\u043d\u0434\u0435\u043c\u0435 \u0441 \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0442\u043e\u0440\u043e\u043c \u0438\u043b\u0438 \u0441 \u0434\u0435\u0441\u0430\u043d\u0442\u043d\u044b\u043c\u0438 \u043f\u0430\u0440\u0430\u0448\u044e\u0442\u0430\u043c\u0438, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043e\u0441\u0432\u0430\u0438\u0432\u0430\u0442\u044c \u0438 \u0441\u043e\u0432\u0435\u0440\u0448\u0435\u043d\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0432\u0441\u0435 \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u0441 \u043e\u043f\u044b\u0442\u043d\u044b\u043c\u0438 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u0430\u043c\u0438. \u0415\u0436\u0435\u0433\u043e\u0434\u043d\u043e \u043d\u0430\u0448\u0438 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u044f\u044e\u0442 \u043f\u0440\u044b\u0436\u043a\u0438 \u0441 \u0434\u0435\u0441\u0430\u043d\u0442\u043d\u044b\u043c \u043f\u0430\u0440\u0430\u0448\u044e\u0442\u043e\u043c \u043f\u043e\u0434 \u0447\u0443\u0442\u043a\u0438\u043c \u0440\u0443\u043a\u043e\u0432\u043e\u0434\u0441\u0442\u0432\u043e\u043c \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0442\u043e\u0440\u043e\u0432 \u00ab\u0410\u044d\u0440\u043e\u043a\u043b\u0430\u0441\u0441\u0438\u043a\u0430\u00bb.<\/p>\n<p>\n<\/div><\/div><\/div><div class=\"kc-elm kc-css-437455 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-6182 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/05\/aero.jpg\" class=\"\" alt=\"\" \/>    <\/div>\n<\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-313539 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-892391 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-500187 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/05\/ayaks.jpg\" class=\"\" alt=\"\" \/>    <\/div>\n<\/div><\/div><div class=\"kc-elm kc-css-285821 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-141905 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">Ayaks Engineering<\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-745462 kc_text_block\"><\/p>\n<p>\u041e\u0434\u0438\u043d \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u0438\u043d\u0442\u0435\u0433\u0440\u0430\u0442\u043e\u0440\u043e\u0432 \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u044b\u0445 \u0441\u0438\u0441\u0442\u0435\u043c \u0437\u0434\u0430\u043d\u0438\u0439 \u0438 \u0441\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u0438\u0439, \u0432\u043a\u043b\u044e\u0447\u0430\u044f \u0446\u0435\u043d\u0442\u0440\u044b \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0434\u0430\u043d\u043d\u044b\u0445 (\u0426\u041e\u0414). \u041a\u043e\u043c\u043f\u0430\u043d\u0438\u044f \u043d\u0430\u0447\u0430\u043b\u0430 \u0441\u0432\u043e\u044e \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0432 1991 \u0433\u043e\u0434\u0443. Ayaks Engineering \u2013 \u043f\u0430\u0440\u0442\u043d\u0451\u0440 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-879276 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-170221 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-309417 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">Ayaks Service<\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-193789 kc_text_block\"><\/p>\n<p>Ayaks Service \u0432\u0445\u043e\u0434\u0438\u0442 \u0432 \u0441\u043e\u0441\u0442\u0430\u0432 \u0433\u0440\u0443\u043f\u043f\u044b \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0439 \u00ab\u0410\u044f\u043a\u0441 \u0413\u0440\u0443\u043f\u043f\u00bb \u0438 \u0432\u043e\u0442 \u0443\u0436\u0435 \u043d\u0430 \u043f\u0440\u043e\u0442\u044f\u0436\u0435\u043d\u0438\u0438 25 \u043b\u0435\u0442 \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \u043f\u043e\u043b\u043d\u044b\u0439 \u0441\u043f\u0435\u043a\u0442\u0440 \u0443\u0441\u043b\u0443\u0433 \u043f\u043e \u0441\u0435\u0440\u0432\u0438\u0441\u043d\u043e\u043c\u0443 \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u044e, \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0435 \u0438 \u0440\u0435\u043c\u043e\u043d\u0442\u0443 \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u044b\u0445 \u0441\u0438\u0441\u0442\u0435\u043c \u0446\u0435\u043d\u0442\u0440\u043e\u0432 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0434\u0430\u043d\u043d\u044b\u0445, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043a\u043e\u043c\u043c\u0435\u0440\u0447\u0435\u0441\u043a\u043e\u0439 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438. \u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u043d\u0430\u043b\u0438\u0447\u0438\u044e \u0432\u044b\u0441\u043e\u043a\u043e\u043a\u0432\u0430\u043b\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445, \u0441\u0435\u0440\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432, \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0433\u043e \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0430, \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u044f \u0438 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0445 \u043b\u0438\u0446\u0435\u043d\u0437\u0438\u0439 \u041e\u041e\u041e \u00ab\u0410\u044f\u043a\u0441 \u0421\u0435\u0440\u0432\u0438\u0441\u00bb \u0432 \u043a\u0440\u0430\u0442\u0447\u0430\u0439\u0448\u0438\u0435 \u0441\u0440\u043e\u043a\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u0438\u0442 \u0440\u0430\u0431\u043e\u0442\u044b \u043b\u044e\u0431\u043e\u0439 \u0441\u043b\u043e\u0436\u043d\u043e\u0441\u0442\u0438 \u043f\u043e \u0432\u043e\u0441\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044e \u0440\u0430\u0431\u043e\u0442\u043e\u0441\u043f\u043e\u0441\u043e\u0431\u043d\u043e\u0441\u0442\u0438 \u0438 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044e \u0431\u0435\u0437\u0430\u0432\u0430\u0440\u0438\u0439\u043d\u043e\u0433\u043e \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u044b\u0445 \u0441\u0438\u0441\u0442\u0435\u043c. \u041f\u0430\u0440\u0442\u043d\u0451\u0440 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb.<\/p>\n<p>\n<\/div><\/div><\/div><div class=\"kc-elm kc-css-182256 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-325079 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/05\/ayaks2.jpg\" class=\"\" alt=\"\" \/>    <\/div>\n<\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-844051 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-364728 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-355128 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/05\/ipresh.jpg\" class=\"\" alt=\"\" \/><div class=\"kc-image-overlay\"><i class=\"sl-share-alt\"><\/i><\/div>    <\/div>\n<\/div><\/div><div class=\"kc-elm kc-css-32208 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-986469 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">IP \u0440\u0435\u0448\u0435\u043d\u0438\u044f <\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-872161 kc_text_block\"><\/p>\n<p>\u041a\u043e\u043c\u043f\u0430\u043d\u0438\u044f \u21161 \u043f\u043e \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0435 \u0432\u0438\u0434\u0435\u043e\u043d\u0430\u0431\u043b\u044e\u0434\u0435\u043d\u0438\u044f \u0434\u043b\u044f \u0447\u0430\u0441\u0442\u043d\u044b\u0445 \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432, \u043c\u0430\u043b\u043e\u0433\u043e \u0438 \u0441\u0440\u0435\u0434\u043d\u0435\u0433\u043e \u0431\u0438\u0437\u043d\u0435\u0441\u0430. \u041f\u0440\u043e\u0435\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435, \u043c\u043e\u043d\u0442\u0430\u0436 \u0438 \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435 \u0441\u0438\u0441\u0442\u0435\u043c \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432 \u041c\u043e\u0441\u043a\u0432\u0435 \u0438 \u041c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438. \u041f\u0430\u0440\u0442\u043d\u0451\u0440 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-460789 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-561842 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-830840 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">STT GROUP <\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-951380 kc_text_block\"><\/p>\n<p>STT GROUP \u0443\u0436\u0435 \u0431\u043e\u043b\u0435\u0435 20 \u043b\u0435\u0442 \u0437\u0430\u043d\u0438\u043c\u0430\u0435\u0442\u0441\u044f \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u043e\u0439 \u0438 \u0441\u0435\u0440\u0438\u0439\u043d\u044b\u043c \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u043e\u043c \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0439 \u0442\u0435\u0445\u043d\u0438\u043a\u0438: \u043d\u0435\u043b\u0438\u043d\u0435\u0439\u043d\u044b\u0445 \u043b\u043e\u043a\u0430\u0442\u043e\u0440\u043e\u0432 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u043e\u0433\u043e \u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f, \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u043e\u0432 \u0440\u0430\u0434\u0438\u043e\u043c\u043e\u043d\u0438\u0442\u043e\u0440\u0438\u043d\u0433\u0430, \u0430\u043f\u043f\u0430\u0440\u0430\u0442\u0443\u0440\u044b \u0432\u0438\u0431\u0440\u043e\u0430\u043a\u0443\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044f \u0438 \u0437\u0430\u0449\u0438\u0442\u044b, \u043f\u0440\u0438\u0431\u043e\u0440\u043e\u0432 \u043f\u043e\u0438\u0441\u043a\u0430 \u043c\u0438\u043d\u043d\u043e-\u0432\u0437\u0440\u044b\u0432\u043d\u044b\u0445 \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432 \u0438 \u043f\u043e\u0440\u0442\u0430\u0442\u0438\u0432\u043d\u044b\u0445 \u0440\u0435\u043d\u0442\u0433\u0435\u043d\u043e\u0432\u0441\u043a\u0438\u0445 \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043e\u043a.<\/p>\n<p>\u041f\u043e\u043c\u0438\u043c\u043e \u044d\u0442\u043e\u0433\u043e, STT GROUP \u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u0443\u0441\u043b\u0443\u0433\u0438 \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u044f\u0442\u0438\u044f\u043c \u0438 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f\u043c \u0432 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u043e\u043d\u043d\u043e\u0439 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438, \u0432\u043a\u043b\u044e\u0447\u0430\u044f \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0430\u043b\u044c\u043d\u043e\u0435 \u043e\u0431\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u043f\u043e\u043c\u0435\u0449\u0435\u043d\u0438\u0439 \u043d\u0430 \u043f\u0440\u0435\u0434\u043c\u0435\u0442 \u0432\u044b\u044f\u0432\u043b\u0435\u043d\u0438\u044f \u043a\u0430\u043d\u0430\u043b\u043e\u0432 \u0443\u0442\u0435\u0447\u043a\u0438 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u0438, \u043c\u043e\u043d\u0442\u0430\u0436 \u0438 \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 (\u0441\u0438\u0441\u0442\u0435\u043c) \u0437\u0430\u0449\u0438\u0442\u044b, \u043f\u0440\u043e\u0435\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0438 \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u043e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u0437\u0430\u0449\u0438\u0449\u0435\u043d\u043d\u044b\u0445 \u043f\u043e\u043c\u0435\u0449\u0435\u043d\u0438\u0439, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u0442 \u0430\u0442\u0442\u0435\u0441\u0442\u0430\u0446\u0438\u044e \u043f\u043e\u043c\u0435\u0449\u0435\u043d\u0438\u0439 \u0438 \u043e\u0431\u044a\u0435\u043a\u0442\u043e\u0432 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u0438 \u043d\u0430 \u0438\u0445 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f\u043c \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u0438. \u041f\u0430\u0440\u0442\u043d\u0451\u0440 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb.<\/p>\n<p>\n<\/div><\/div><\/div><div class=\"kc-elm kc-css-137975 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-398582 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/05\/ind-logo.jpg\" class=\"\" alt=\"\" \/>    <\/div>\n<\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-241457 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-292252 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-177474 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/09\/carobus24.png\" class=\"\" alt=\"\" \/>    <\/div>\n<\/div><\/div><div class=\"kc-elm kc-css-957099 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-887868 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">CAROBUS24<\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-647615 kc_text_block\"><\/p>\n<p>\u041a\u043e\u043c\u043f\u0430\u043d\u0438\u044f Carobus24 \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \u043f\u043e\u043b\u043d\u044b\u0439 \u0441\u043f\u0435\u043a\u0442\u0440 \u0443\u0441\u043b\u0443\u0433, \u0441\u04