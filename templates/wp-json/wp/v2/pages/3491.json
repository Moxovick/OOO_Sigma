{"id":3491,"date":"2019-03-14T18:30:56","date_gmt":"2019-03-14T15:30:56","guid":{"rendered":"http:\/\/sigma-profi.org\/?page_id=3491"},"modified":"2025-04-01T16:00:19","modified_gmt":"2025-04-01T13:00:19","slug":"nashi-klienty","status":"publish","type":"page","link":"https:\/\/sigma-profi.org\/nashi-klienty\/","title":{"rendered":"\u041d\u0430\u0448\u0438 \u043a\u043b\u0438\u0435\u043d\u0442\u044b"},"content":{"rendered":"<p><section class=\"kc-elm kc-css-145327 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-159927 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div class=\"kc-elm kc-css-809415 kc_text_block\"><\/p>\n<p>\n\u041a\u043b\u0438\u0435\u043d\u0442\u0430\u043c\u0438 \u0413\u041a \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438 \u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f \u0440\u043e\u0441\u0441\u0438\u0439\u0441\u043a\u0438\u0435 \u0438 \u043c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u044b\u0435 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u0441\u0440\u0435\u0434\u043d\u0435\u0433\u043e \u0438 \u043a\u0440\u0443\u043f\u043d\u043e\u0433\u043e \u0431\u0438\u0437\u043d\u0435\u0441\u0430 \u0432 \u0441\u0430\u043c\u044b\u0445 \u0440\u0430\u0437\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u043d\u044b\u0445 \u0441\u0444\u0435\u0440\u0430\u0445.<\/p>\n<p>\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0440\u0438 \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u0438 \u0438 \u043f\u0440\u0435\u0443\u0441\u043f\u0435\u0432\u0430\u043d\u0438\u0438 \u043d\u0430\u0448\u0438\u0445 \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u043e\u0432, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u0432\u043e\u043f\u0440\u043e\u0441 \u0440\u0435\u043f\u0443\u0442\u0430\u0446\u0438\u0438 \u0434\u043b\u044f \u043d\u0430\u0441 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u043c. \u0417\u0430 \u0432\u0440\u0435\u043c\u044f \u0440\u0430\u0431\u043e\u0442\u044b \u043c\u044b \u0432\u044b\u0441\u0442\u0440\u043e\u0438\u043b\u0438 \u043d\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u0438 \u0434\u043e\u043b\u0433\u043e\u0441\u0440\u043e\u0447\u043d\u044b\u0435 \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u044f \u0441 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u043c\u0438 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044f\u043c\u0438. \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u043e\u0445\u0440\u0430\u043d\u044f\u0435\u0442 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 \u0438 \u043a\u043e\u043c\u043c\u0435\u0440\u0447\u0435\u0441\u043a\u0438\u0435 \u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u044b, \u043a\u043e\u0442\u0442\u0435\u0434\u0436\u043d\u044b\u0435 \u043f\u043e\u0441\u0435\u043b\u043a\u0438, \u0442\u043e\u0440\u0433\u043e\u0432\u044b\u0435 \u0438 \u0431\u0438\u0437\u043d\u0435\u0441-\u0446\u0435\u043d\u0442\u0440\u044b, \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0438 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 \u043e\u0431\u044a\u0435\u043a\u0442\u044b, \u0433\u043e\u0441\u0442\u0438\u043d\u0438\u0447\u043d\u044b\u0435 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u044b \u0438 \u043f\u0440. \u041d\u0430\u043c \u0434\u043e\u0432\u0435\u0440\u044f\u044e\u0442 \u043b\u0438\u0447\u043d\u0443\u044e \u043e\u0445\u0440\u0430\u043d\u0443, \u0441\u043e\u043f\u0440\u043e\u0432\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0446\u0435\u043d\u043d\u044b\u0445 \u0433\u0440\u0443\u0437\u043e\u0432, \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u043c\u0430\u0441\u0441\u043e\u0432\u044b\u0445 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u0439.<br \/>\u0421\u0440\u0435\u0434\u0438 \u043d\u0430\u0448\u0438\u0445 \u043c\u043d\u043e\u0433\u043e\u0447\u0438\u0441\u043b\u0435\u043d\u043d\u044b\u0445 \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432 \u0432\u044b\u0434\u0435\u043b\u0438\u043c \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438, \u0441\u043f\u0435\u0446\u0438\u0444\u0438\u043a\u0430 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u043a\u043e\u0442\u043e\u0440\u044b\u0445, \u043d\u0430 \u043d\u0430\u0448 \u0432\u0437\u0433\u043b\u044f\u0434, \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u0412\u0430\u043c \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u0430.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><\/div><\/section><section class=\"kc-elm kc-css-8757 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-565039 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-358736 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-254223 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-889520 kc_shortcode kc_single_image\">\n\n        <a  href=\"http:\/\/sigma-profi.org\/nashi-klienty\/balchug-kempinski\/\" title=\"\u0411\u0430\u043b\u0447\u0443\u0433 \u041a\u0435\u043c\u043f\u0438\u043d\u0441\u043a\u0438\" target=\"_self\">\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2017\/07\/4.jpg\" class=\"\" alt=\"\" \/><div class=\"kc-image-overlay\"><i class=\"sl-share-alt\"><\/i><\/div>    <\/a>\n    <\/div>\n<\/div><\/div><div class=\"kc-elm kc-css-335038 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-123753 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\"><a href=\"http:\/\/sigma-profi.org\/nashi-klienty\/balchug-kempinski\/\" class=\"kc_title_link\" title=\"\u0411\u0430\u043b\u0447\u0443\u0433 \u041a\u0435\u043c\u043f\u0438\u043d\u0441\u043a\u0438\" target=\"\">\u041e\u0442\u0435\u043b\u044c \u00ab\u0411\u0430\u043b\u0447\u0443\u0433 \u041a\u0435\u043c\u043f\u0438\u043d\u0441\u043a\u0438\u00bb <\/a><\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-651933 kc_text_block\"><\/p>\n<p>\n\u041e\u0442\u0435\u043b\u044c \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0438\u043b\u0441\u044f \u0432 \u0441\u0430\u043c\u043e\u043c \u0446\u0435\u043d\u0442\u0440\u0435 \u0441\u0442\u043e\u043b\u0438\u0446\u044b, \u0432 \u043a\u0440\u0430\u0441\u0438\u0432\u0435\u0439\u0448\u0435\u043c \u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u043e\u043c \u0440\u0430\u0439\u043e\u043d\u0435 \u0417\u0430\u043c\u043e\u0441\u043a\u0432\u043e\u0440\u0435\u0447\u044c\u0435. \u0418\u0437 \u043e\u043a\u043e\u043d \u0431\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u0430 \u043d\u043e\u043c\u0435\u0440\u043e\u0432, \u043a\u043e\u043d\u0444\u0435\u0440\u0435\u043d\u0446-\u0437\u0430\u043b\u043e\u0432 \u0438 \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d\u043e\u0432 \u043e\u0442\u0435\u043b\u044f \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043f\u0430\u043d\u043e\u0440\u0430\u043c\u043d\u044b\u0439 \u0432\u0438\u0434 \u043d\u0430 \u041a\u0440\u0435\u043c\u043b\u044c, \u041a\u0440\u0430\u0441\u043d\u0443\u044e \u043f\u043b\u043e\u0449\u0430\u0434\u044c \u0438 \u0441\u043e\u0431\u043e\u0440 \u0412\u0430\u0441\u0438\u043b\u0438\u044f \u0411\u043b\u0430\u0436\u0435\u043d\u043d\u043e\u0433\u043e.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-189592 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-684328 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-632267 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">\u0413\u043e\u0441\u0442\u0438\u043d\u0438\u0446\u0430 \u00ab\u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442-\u041e\u0442\u0435\u043b\u044c\u00bb <\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-998366 kc_text_block\"><\/p>\n<p>\u0413\u043e\u0441\u0442\u0438\u043d\u0438\u0446\u0430 \u00ab\u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442-\u041e\u0442\u0435\u043b\u044c\u00bb &#8212; \u043e\u0434\u043d\u0430 \u0438\u0437 \u043a\u0440\u0443\u043f\u043d\u0435\u0439\u0448\u0438\u0445 \u0433\u043e\u0441\u0442\u0438\u043d\u0438\u0446 \u041c\u043e\u0441\u043a\u0432\u044b, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0430 \u043d\u0430 \u0436\u0438\u0432\u043e\u043f\u0438\u0441\u043d\u043e\u043c \u0431\u0435\u0440\u0435\u0433\u0443 \u041c\u043e\u0441\u043a\u0432\u0430-\u0440\u0435\u043a\u0438, \u0432 \u0441\u0430\u043c\u043e\u043c \u0446\u0435\u043d\u0442\u0440\u0435 \u0434\u0435\u043b\u043e\u0432\u043e\u0439 \u0438 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u043d\u043e\u0439 \u0436\u0438\u0437\u043d\u0438 \u0441\u0442\u043e\u043b\u0438\u0446\u044b. \u0421 \u0432\u0435\u0440\u0445\u043d\u0438\u0445 \u044d\u0442\u0430\u0436\u0435\u0439 \u0433\u043e\u0441\u0442\u0438\u043d\u0438\u0446\u044b \u00ab\u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442-\u041e\u0442\u0435\u043b\u044c\u00bb \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043f\u0440\u0435\u043a\u0440\u0430\u0441\u043d\u044b\u0439 \u043f\u0430\u043d\u043e\u0440\u0430\u043c\u043d\u044b\u0439 \u0432\u0438\u0434 \u043d\u0430 \u0446\u0435\u043d\u0442\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u0447\u0430\u0441\u0442\u044c \u0433\u043e\u0440\u043e\u0434\u0430, \u043f\u0430\u043c\u044f\u0442\u043d\u0438\u043a \u041f\u0435\u0442\u0440\u0443 I, \u0425\u0440\u0430\u043c \u0425\u0440\u0438\u0441\u0442\u0430 \u0421\u043f\u0430\u0441\u0438\u0442\u0435\u043b\u044f \u0438 \u0443\u043b\u0438\u0446\u0443 \u0411\u043e\u043b\u044c\u0448\u0430\u044f \u042f\u043a\u0438\u043c\u0430\u043d\u043a\u0430.<\/p>\n<p>\u0412\u043e\u0442 \u0443\u0436\u0435 40 \u043b\u0435\u0442 \u0433\u043e\u0441\u0442\u0438\u043d\u0438\u0446\u0430 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432\u0430\u0436\u043d\u043e\u0439, \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044e\u0449\u0435\u0439 \u0447\u0430\u0441\u0442\u044c\u044e \u0441\u0438\u0441\u0442\u0435\u043c\u044b \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0432\u044b\u0441\u0448\u0438\u0445 \u043e\u0440\u0433\u0430\u043d\u043e\u0432 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0432\u043b\u0430\u0441\u0442\u0438. \u00ab\u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442-\u041e\u0442\u0435\u043b\u044c\u00bb \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043e\u043d\u043d\u043e \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043c\u0435\u0441\u0442\u043e\u043c \u043f\u0440\u043e\u0432\u0435\u0434\u0435\u043d\u0438\u044f \u0432\u0441\u0442\u0440\u0435\u0447 \u0433\u043b\u0430\u0432 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432 \u0438 \u043f\u0440\u0430\u0432\u0438\u0442\u0435\u043b\u044c\u0441\u0442\u0432, \u043c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u044b\u0445 \u0444\u043e\u0440\u0443\u043c\u043e\u0432, \u043a\u043e\u043d\u0433\u0440\u0435\u0441\u0441\u043e\u0432, \u043a\u043e\u043d\u0444\u0435\u0440\u0435\u043d\u0446\u0438\u0439, \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u0439 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043b\u0435\u0439 \u043f\u043e\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0439, \u0431\u0438\u0437\u043d\u0435\u0441\u0430, \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u044b, \u0438\u0441\u043a\u0443\u0441\u0441\u0442\u0432\u0430 \u0438 \u0441\u043f\u043e\u0440\u0442\u0430.<\/p>\n<p>\n<\/div><\/div><\/div><div class=\"kc-elm kc-css-949444 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-347315 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2019\/09\/presidenthotel.jpg\" class=\"\" alt=\"\" \/><div class=\"kc-image-overlay\"><i class=\"sl-share-alt\"><\/i><\/div>    <\/div>\n<\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-39257 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-41665 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-98275 kc_shortcode kc_single_image\">\n\n        <img decoding=\"async\" src=\"https:\/\/sigma-profi.org\/wp-content\/uploads\/2025\/03\/4seasons_logo.jpg\" class=\"\" alt=\"\" \/><div class=\"kc-image-overlay\"><i class=\"sl-share-alt\"><\/i><\/div>    <\/div>\n<\/div><\/div><div class=\"kc-elm kc-css-390414 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-647190 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">\u041e\u0442\u0435\u043b\u044c \u00abFour Seasons Moscow\u00bb <\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-311192 kc_text_block\"><\/p>\n<p>\u0412 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u0445 \u0448\u0430\u0433\u0430\u0445 \u043e\u0442 \u041a\u0440\u0435\u043c\u043b\u044f \u0438 \u041a\u0440\u0430\u0441\u043d\u043e\u0439 \u043f\u043b\u043e\u0449\u0430\u0434\u0438, \u0432 Four Seasons Hotel Moscow, \u043d\u0430\u0441\u043b\u0435\u0434\u0438\u0435 \u0438\u0441\u0442\u043e\u0440\u0438\u0438 \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u043e \u0441\u043e\u0447\u0435\u0442\u0430\u0435\u0442\u0441\u044f \u0441 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u043c \u0434\u0438\u0437\u0430\u0439\u043d\u043e\u043c. \u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0434\u043b\u044f \u0441\u0435\u0431\u044f \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u0443\u044e \u0432\u0435\u0440\u0441\u0438\u044e \u043b\u0435\u0433\u0435\u043d\u0434\u0430\u0440\u043d\u043e\u0439 \u0433\u043e\u0441\u0442\u0438\u043d\u0438\u0446\u044b \u00ab\u041c\u043e\u0441\u043a\u0432\u0430\u00bb 1930-\u0445 \u0433\u043e\u0434\u043e\u0432, \u0447\u0442\u043e\u0431\u044b \u043d\u0430\u0441\u043b\u0430\u0434\u0438\u0442\u044c\u0441\u044f \u043f\u0430\u043d\u043e\u0440\u0430\u043c\u043d\u044b\u043c \u0432\u0438\u0434\u043e\u043c \u043d\u0430 \u0437\u043d\u0430\u043a\u043e\u0432\u044b\u0435 \u0434\u043e\u0441\u0442\u043e\u043f\u0440\u0438\u043c\u0435\u0447\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u043c \u0441\u0435\u0440\u0432\u0438\u0441\u043e\u043c \u0432 \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d\u0430\u0445 \u0438 \u0441\u043f\u0430 \u0438 \u043f\u043e\u0434\u0430\u0440\u0438\u0442\u044c \u043d\u0435\u0437\u0430\u0431\u044b\u0432\u0430\u0435\u043c\u044b\u0435 \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u044f \u0441\u0435\u0431\u0435 \u0438 \u0441\u0432\u043e\u0438\u043c \u0431\u043b\u0438\u0437\u043a\u0438\u043c \u0432 \u0441\u0430\u043c\u043e\u043c \u0441\u0435\u0440\u0434\u0446\u0435 \u0441\u0442\u043e\u043b\u0438\u0446\u044b.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><div data-kc-equalheight=\"true\" data-kc-row-action=\"true\" data-kc-equalheight-align=\"middle\" class=\"kc-elm kc-css-807390 kc_row kc_row_inner klienty\"><div class=\"kc-elm kc-css-405213 kc_col-sm-8 kc_column_inner kc_col-sm-8\"><div class=\"kc_wrapper kc-col-inner-container\">\n<div class=\"kc-elm kc-css-5798