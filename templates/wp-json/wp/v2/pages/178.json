{"id":178,"date":"2017-08-14T14:09:31","date_gmt":"2017-08-14T11:09:31","guid":{"rendered":"http:\/\/sigma-profi.org\/?page_id=178"},"modified":"2020-11-23T12:11:05","modified_gmt":"2020-11-23T09:11:05","slug":"salonov-krasoty","status":"publish","type":"page","link":"https:\/\/sigma-profi.org\/uslugi\/ohrana-obektov\/nedvizhimosti\/kommercheskih-obektov\/salonov-krasoty\/","title":{"rendered":"\u041e\u0445\u0440\u0430\u043d\u0430 \u0441\u0430\u043b\u043e\u043d\u043e\u0432 \u043a\u0440\u0430\u0441\u043e\u0442\u044b"},"content":{"rendered":"<p><section class=\"kc-elm kc-css-990945 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><\/div><\/div><\/section><section class=\"kc-elm kc-css-184348 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-933658 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div class=\"kc-elm kc-css-805413 kc_row kc_row_inner\"><div class=\"kc-elm kc-css-786141 kc_col-sm-12 kc_column_inner kc_col-sm-12\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-753992 kc_text_block\"><\/p>\n<p>\n\u0427\u041e\u041f \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb \u043e\u0445\u0440\u0430\u043d\u044f\u0435\u0442 \u0441\u0430\u043b\u043e\u043d\u044b \u043a\u0440\u0430\u0441\u043e\u0442\u044b \u0440\u0430\u0437\u043d\u043e\u0433\u043e \u0443\u0440\u043e\u0432\u043d\u044f: \u043e\u0442 \u044d\u043a\u043e\u043d\u043e\u043c- \u0434\u043e \u043f\u0440\u0435\u043c\u0438\u0443\u043c-\u043a\u043b\u0430\u0441\u0441\u0430. \u041c\u043d\u043e\u0433\u043e\u043b\u0435\u0442\u043d\u0438\u0439 \u043e\u043f\u044b\u0442 \u0440\u0430\u0431\u043e\u0442\u044b \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u0432\u044b\u0441\u043e\u043a\u043e\u043a\u043b\u0430\u0441\u0441\u043d\u044b\u0435 \u0443\u0441\u043b\u0443\u0433\u0438 \u043f\u043e \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0438 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u0434\u0430\u043d\u043d\u044b\u0445 \u0437\u0430\u0432\u0435\u0434\u0435\u043d\u0438\u0439 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u0438\u0445 \u0441\u043f\u0435\u0446\u0438\u0444\u0438\u043a\u0438.<\/p>\n<h2>\u0421\u043f\u0435\u0446\u0438\u0444\u0438\u043a\u0430 \u043e\u0445\u0440\u0430\u043d\u044b \u0441\u0430\u043b\u043e\u043d\u043e\u0432 \u043a\u0440\u0430\u0441\u043e\u0442\u044b<\/h2>\n<p><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full\" src=\"http:\/\/sigma-profi.org\/wp-content\/uploads\/2018\/09\/konsultirovanie-bezopasnosti.jpg\" alt=\"\" width=\"870\" height=\"400\" \/><\/p>\n<p>\u041e\u0434\u043d\u0430 \u0438\u0437 \u0433\u043b\u0430\u0432\u043d\u044b\u0445 \u0437\u0430\u0434\u0430\u0447 \u043d\u0430\u0448\u0435\u0439 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u2013 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435 \u0441\u043e\u0445\u0440\u0430\u043d\u043d\u043e\u0441\u0442\u0438 \u0434\u043e\u0440\u043e\u0433\u043e\u0441\u0442\u043e\u044f\u0449\u0435\u0433\u043e \u043a\u043e\u0441\u043c\u0435\u0442\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0438 \u043c\u0435\u0434\u0438\u0446\u0438\u043d\u0441\u043a\u043e\u0433\u043e \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u044f, \u043a\u043e\u0442\u043e\u0440\u044b\u043c \u0441\u0435\u0433\u043e\u0434\u043d\u044f \u043e\u0441\u043d\u0430\u0449\u0430\u044e\u0442\u0441\u044f \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u0432\u0441\u0435 \u0446\u0435\u043d\u0442\u0440\u044b \u043a\u0440\u0430\u0441\u043e\u0442\u044b \u0438 \u0437\u0434\u043e\u0440\u043e\u0432\u044c\u044f.<\/p>\n<p>\u0422\u0430\u043a\u0436\u0435 \u0446\u0435\u043b\u044c\u044e \u0427\u041e\u041f\u0430 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0437\u0430\u0449\u0438\u0442\u0430 \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u043b\u0430 \u0438 \u043f\u043e\u0441\u0435\u0442\u0438\u0442\u0435\u043b\u0435\u0439 \u043e\u0442 \u043d\u0430\u043f\u0430\u0434\u0435\u043d\u0438\u0439 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u044b\u0445 \u0443\u0433\u0440\u043e\u0437. \u041d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0441\u0430\u043b\u043e\u043d \u043a\u0440\u0430\u0441\u043e\u0442\u044b \u043d\u0435\u0440\u0435\u0434\u043a\u043e \u043f\u043e\u0441\u0435\u0449\u0430\u044e\u0442 \u043c\u0435\u0434\u0438\u0439\u043d\u044b\u0435 \u043b\u044e\u0434\u0438, \u043f\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u043d\u043e\u0439 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438, \u0442\u0430\u043a \u043a\u0430\u043a \u0443 \u0437\u043d\u0430\u043c\u0435\u043d\u0438\u0442\u043e\u0441\u0442\u0435\u0439 \u0435\u0441\u0442\u044c \u043d\u0435\u0434\u043e\u0431\u0440\u043e\u0436\u0435\u043b\u0430\u0442\u0435\u043b\u0438, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044e\u0449\u0438\u0435 \u043b\u044e\u0431\u043e\u0439 \u043c\u043e\u043c\u0435\u043d\u0442, \u0447\u0442\u043e\u0431\u044b \u0441\u043a\u043e\u043c\u043f\u0440\u043e\u043c\u0435\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0438\u0445 \u0438 \u0440\u0430\u0437\u0436\u0435\u0447\u044c \u043a\u043e\u043d\u0444\u043b\u0438\u043a\u0442.<\/p>\n<h2>\u0423\u0441\u043b\u0443\u0433\u0438 \u043f\u043e \u043e\u0445\u0440\u0430\u043d\u0435 \u0446\u0435\u043d\u0442\u0440\u043e\u0432 \u043a\u0440\u0430\u0441\u043e\u0442\u044b<\/h2>\n<p><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full\" src=\"http:\/\/sigma-profi.org\/wp-content\/uploads\/2018\/09\/ohrana-restoranov.jpg\" alt=\"\" width=\"870\" height=\"400\" \/><\/p>\n<p>\u041d\u0430\u0448\u0435 \u0447\u0430\u0441\u0442\u043d\u043e\u0435 \u043e\u0445\u0440\u0430\u043d\u043d\u043e\u0435 \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u044f\u0442\u0438\u0435 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442:<\/p>\n<ul>\n<li>\u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044e \u0438 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u0435 \u043e\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u043f\u043e\u0440\u044f\u0434\u043a\u0430 \u043a\u0430\u043a \u0432 \u0441\u0430\u043c\u043e\u043c \u0441\u0430\u043b\u043e\u043d\u0435 \u043a\u0440\u0430\u0441\u043e\u0442\u044b, \u0442\u0430\u043a \u0438 \u043d\u0430 \u043f\u0440\u0438\u043b\u0435\u0433\u0430\u044e\u0449\u0435\u0439 \u043a \u043d\u0435\u043c\u0443 \u0442\u0435\u0440\u0440\u0438\u0442\u043e\u0440\u0438\u0438;<\/li>\n<li>\u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u043f\u043e\u0441\u0435\u0442\u0438\u0442\u0435\u043b\u0435\u0439 \u0438 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438;<\/li>\n<li>\u043f\u043e\u043b\u043d\u0443\u044e \u0441\u043e\u0445\u0440\u0430\u043d\u043d\u043e\u0441\u0442\u044c \u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430 \u0432\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0433\u043e \u043e\u0431\u044a\u0435\u043a\u0442\u0430;<\/li>\n<li>\u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u0435\u043d\u0438\u0435 \u0440\u044f\u0434\u0430 \u043c\u0435\u0440 \u043f\u043e \u043f\u0440\u0435\u0441\u0435\u0447\u0435\u043d\u0438\u044e \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0437\u043b\u043e\u0443\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u0438\u043a\u043e\u0432;<\/li>\n<li>\u043e\u0445\u0440\u0430\u043d\u0443 \u043f\u0430\u0440\u043a\u043e\u0432\u043a\u0438;<\/li>\n<li>\u043a\u0440\u0443\u0433\u043b\u043e\u0441\u0443\u0442\u043e\u0447\u043d\u043e\u0435 \u043f\u0430\u0442\u0440\u0443\u043b\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0442\u0435\u0440\u0440\u0438\u0442\u043e\u0440\u0438\u0438;<\/li>\n<li>\u0432\u0438\u0434\u0435\u043e\u043d\u0430\u0431\u043b\u044e\u0434\u0435\u043d\u0438\u0435:<\/li>\n<li>\u043f\u0440\u043e\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0430\u043d\u0442\u0438\u0442\u0435\u0440\u0440\u043e\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u0439 \u0438 \u043f\u0440.<\/li>\n<\/ul>\n<h2>\u0414\u043e\u0441\u0442\u043e\u0438\u043d\u0441\u0442\u0432\u0430 \u0427\u041e\u041f \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb<\/h2>\n<p>\u0423 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u043d\u0430\u043a\u043e\u043f\u043b\u0435\u043d \u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u043e\u043f\u044b\u0442 \u0432 \u0441\u0444\u0435\u0440\u0435 \u043e\u0445\u0440\u0430\u043d\u043d\u044b\u0445 \u0443\u0441\u043b\u0443\u0433. \u041c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u043d\u0430\u0448\u0438\u0445 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u044b\u0445 \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432 \u2013 \u044d\u0442\u043e \u043b\u0443\u0447\u0448\u0430\u044f \u043e\u0446\u0435\u043d\u043a\u0430 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430 \u0440\u0430\u0431\u043e\u0442\u044b \u0438 \u0443\u0441\u043f\u0435\u0448\u043d\u043e \u0440\u0435\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432 \u043f\u043e \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044e \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438.<\/p>\n<p>\u0412 \u0448\u043a\u043e\u043b\u0435 \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438 \u0426\u0435\u043d\u0442\u0440\u00bb \u0431\u043e\u0439\u0446\u044b \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0442 \u0440\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e\u0435 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0435 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435, \u0432\u043a\u043b\u044e\u0447\u0430\u044e\u0449\u0435\u0435 \u043c\u0435\u0434\u0438\u0446\u0438\u043d\u0441\u043a\u0443\u044e, \u043f\u0440\u0430\u0432\u043e\u0432\u0443\u044e, \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0443\u044e, \u043e\u0433\u043d\u0435\u0432\u0443\u044e, \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0443\u044e \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0443. \u041c\u043d\u043e\u0433\u0438\u0435 \u043e\u0445\u0440\u0430\u043d\u043d\u0438\u043a\u0438 \u0438\u043c\u0435\u044e\u0442 \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u0435 \u0440\u0430\u0437\u0440\u044f\u0434\u044b \u0432 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0445 \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044f\u0445.<\/p>\n<p><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full\" src=\"http:\/\/sigma-profi.org\/wp-content\/uploads\/2018\/09\/ohrana-salonov-krasoty3.jpg\" alt=\"\" width=\"870\" height=\"400\" \/><\/p>\n<p>\u041b\u0438\u0446\u0435\u043d\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0435 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0438 \u043d\u0430\u0448\u0435\u0433\u043e \u0427\u041e\u041f\u0430 \u043c\u043e\u0433\u0443\u0442 \u0440\u0430\u0431\u043e\u0442\u0430\u0442\u044c \u043a\u0430\u043a \u0431\u0435\u0437 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0437\u0430\u0449\u0438\u0442\u044b, \u0442\u0430\u043a \u0438 \u0441 \u0438\u0445 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435\u043c. \u041f\u0440\u0438 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u0432\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u043e\u0439 \u043e\u0445\u0440\u0430\u043d\u044b \u0431\u043e\u0439\u0446\u044b \u044d\u043a\u0438\u043f\u0438\u0440\u043e\u0432\u0430\u043d\u044b \u043f\u0438\u0441\u0442\u043e\u043b\u0435\u0442\u0430\u043c\u0438, \u0440\u0443\u0436\u044c\u044f\u043c\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0441\u043f\u0435\u0446\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043c\u0438.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><\/div><\/div><\/div><\/div><\/section><section class=\"kc-elm kc-css-864179 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><\/div><\/div><\/section><section class=\"kc-elm kc-css-406577 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-970391 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\">\n<div class=\"kc-elm kc-css-279965 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">\u041a\u0430\u043a \u043c\u044b \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u043c<\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-908979 kc_row kc_row_inner\"><div class=\"kc-elm kc-css-467298 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-564150 kc-raw-code\"><div class=\"shagblock\">\r\n\t<div class=\"shagnum\">\r\n\t1\r\n\t<\/div>\r\n\t<div class=\"shagicon\">\r\n\t\t<i class=\"fa fa-phone\" aria-hidden=\"true\"><\/i>\r\n\t<\/div>\r\n\t<div class=\"shagcont\">\r\n\t\t<span>\u041c\u044b \u0432\u0441\u0435\u0433\u0434\u0430 \u043d\u0430 \u0441\u0432\u044f\u0437\u0438<\/span>\r\n\t\t<p>\u041c\u044b \u043d\u0430 \u0441\u0432\u044f\u0437\u0438 24 \u0447\u0430\u0441\u0430 \u0432 \u0441\u0443\u0442\u043a\u0438, 7 \u0434\u043d\u0435\u0439 \u0432 \u043d\u0435\u0434\u0435\u043b\u044e: \u043f\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0443, \u043f\u043e