{"id":124,"date":"2017-08-14T14:00:25","date_gmt":"2017-08-14T11:00:25","guid":{"rendered":"http:\/\/sigma-profi.org\/?page_id=124"},"modified":"2020-11-23T13:00:45","modified_gmt":"2020-11-23T10:00:45","slug":"aptek","status":"publish","type":"page","link":"https:\/\/sigma-profi.org\/uslugi\/ohrana-obektov\/organizatsij\/meditsinskih-uchrezhdenij\/aptek\/","title":{"rendered":"\u041e\u0445\u0440\u0430\u043d\u0430 \u0430\u043f\u0442\u0435\u043a"},"content":{"rendered":"<p><section class=\"kc-elm kc-css-832985 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><\/div><\/div><\/section><section class=\"kc-elm kc-css-454570 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-604031 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\"><div class=\"kc-elm kc-css-120961 kc_row kc_row_inner\"><div class=\"kc-elm kc-css-144447 kc_col-sm-12 kc_column_inner kc_col-sm-12\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-399572 kc_text_block\"><\/p>\n<p>\n\u0424\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u043e\u0445\u0440\u0430\u043d\u0430 \u0430\u043f\u0442\u0435\u043a \u2013 \u044d\u0442\u043e \u0441\u043f\u0435\u0446\u0438\u0444\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0432\u0438\u0434 \u0437\u0430\u0449\u0438\u0442\u044b \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u0439, \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u044e\u0449\u0438\u0445 \u043f\u0440\u043e\u0434\u0430\u0436\u0443 \u0444\u0430\u0440\u043c\u0430\u043a\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0442\u043e\u0432\u0430\u0440\u043e\u0432 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u0438\u044e.<\/p>\n<p>\u0412 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0435\u0435 \u0432\u0440\u0435\u043c\u044f, \u0432\u0432\u0438\u0434\u0443 \u0443\u0447\u0430\u0441\u0442\u0438\u0432\u0448\u0438\u0445\u0441\u044f \u0441\u043b\u0443\u0447\u0430\u0435\u0432 \u043e\u0433\u0440\u0430\u0431\u043b\u0435\u043d\u0438\u0439 \u0438 \u043d\u0430\u043f\u0430\u0434\u0435\u043d\u0438\u0439 \u043d\u0430 \u043f\u0440\u043e\u0432\u0438\u0437\u043e\u0440\u043e\u0432, \u043e\u0442\u043f\u0443\u0441\u043a\u0430\u044e\u0449\u0438\u0445 \u043d\u0430\u0440\u043a\u043e\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0438\u043b\u0438 \u0441\u043f\u0438\u0440\u0442\u043e\u0441\u043e\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0435 \u043f\u0440\u0435\u043f\u0430\u0440\u0430\u0442\u044b, \u0432\u043e\u043f\u0440\u043e\u0441\u044b \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u0443\u044e\u0449\u0435\u0433\u043e \u0430\u043f\u0442\u0435\u0447\u043d\u043e\u0433\u043e \u0431\u0438\u0437\u043d\u0435\u0441\u0430 \u0441\u0442\u0430\u043b\u0438 \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u044b.<\/p>\n<h2>\u0422\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f \u043a \u043e\u0445\u0440\u0430\u043d\u0435 \u0430\u043f\u0442\u0435\u043a<\/h2>\n<p>\u041e\u0445\u0440\u0430\u043d\u0430 \u0430\u043f\u0442\u0435\u043a \u0434\u043e\u043b\u0436\u043d\u0430 \u043e\u0442\u0432\u0435\u0447\u0430\u0442\u044c \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u043c \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u043c \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f\u043c, \u0430 \u0438\u043c\u0435\u043d\u043d\u043e:<\/p>\n<ul>\n<li>\u043d\u0430\u0434\u0435\u0436\u043d\u043e\u0441\u0442\u044c,<\/li>\n<li>\u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c,<\/li>\n<li>\u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u0430\u044f \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u043f\u0440\u0438 \u043c\u0438\u043d\u0438\u043c\u0443\u043c\u0435 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u0438 \u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 \u0437\u0430\u0442\u0440\u0430\u0442,<\/li>\n<li>\u043e\u0441\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u043e \u0442\u0435\u043a\u0443\u0449\u0435\u0439 \u043a\u0440\u0438\u043c\u0438\u043d\u043e\u0433\u0435\u043d\u043d\u043e\u0439 \u043e\u0431\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0435 \u0432 \u0440\u0430\u0439\u043e\u043d\u0435, \u0433\u0434\u0435 \u043d\u0430\u0445\u043e\u0434\u0438\u0442\u0441\u044f \u043f\u043e\u0434\u0432\u0435\u0434\u043e\u043c\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u043e\u0431\u044a\u0435\u043a\u0442.<\/li>\n<\/ul>\n<h2>\u0421\u043f\u043e\u0441\u043e\u0431\u044b \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u043e\u0445\u0440\u0430\u043d\u044b \u0430\u043f\u0442\u0435\u043a<\/h2>\n<p>\u041a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u043e\u0445\u0440\u0430\u043d\u0430 \u0430\u043f\u0442\u0435\u043a \u0427\u041e\u041f\u043e\u043c \u0434\u043e\u0441\u0442\u0438\u0433\u0430\u0435\u0442\u0441\u044f \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u043d\u043d\u043e\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u043d\u043e\u0439 \u0441\u0438\u0441\u0442\u0435\u043c\u044b, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0432\u0430\u0435\u0442 \u043f\u0440\u0435\u0434\u0443\u043f\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u0435 \u043f\u0440\u043e\u0442\u0438\u0432\u043e\u043f\u0440\u0430\u0432\u043d\u044b\u0445 \u0434\u0435\u044f\u043d\u0438\u0439, \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0435\u043c\u044b\u0445 \u0437\u043b\u043e\u0443\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u0438\u043a\u0430\u043c\u0438, \u0432 \u0442\u043e\u043c \u0447\u0438\u0441\u043b\u0435 \u043d\u0435\u0434\u043e\u043f\u0443\u0449\u0435\u043d\u0438\u0435 \u043f\u0440\u043e\u043d\u0438\u043a\u043d\u043e\u0432\u0435\u043d\u0438\u044f \u043f\u043e\u0441\u0442\u043e\u0440\u043e\u043d\u043d\u0438\u0445 \u043b\u0438\u0446 \u0432 \u0441\u043b\u0443\u0436\u0435\u0431\u043d\u044b\u0435 \u043f\u043e\u043c\u0435\u0449\u0435\u043d\u0438\u044f \u0441 \u0446\u0435\u043b\u044c\u044e \u043a\u0440\u0430\u0436\u0438 \u043c\u0435\u0434\u0438\u043a\u0430\u043c\u0435\u043d\u0442\u043e\u0432.<\/p>\n<p>\u0417\u0430\u0449\u0438\u0442\u0430 \u0430\u043f\u0442\u0435\u0447\u043d\u044b\u0445 \u0441\u0435\u0442\u0435\u0439 \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0445 \u043c\u0435\u0440 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043e\u0445\u0440\u0430\u043d\u044b \u043e\u0431\u044a\u0435\u043a\u0442\u0430:<\/p>\n<ul>\n<li>\u043a\u0440\u0443\u0433\u043b\u043e\u0441\u0443\u0442\u043e\u0447\u043d\u043e\u0435 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u043f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043e\u043c \u0434\u0435\u0436\u0443\u0440\u0441\u0442\u0432\u0430 \u043d\u0435\u0432\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u044b\u0445 \u043a\u0432\u0430\u043b\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0438 \u043b\u0438\u0446\u0435\u043d\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u043e\u0445\u0440\u0430\u043d\u043d\u0438\u043a\u043e\u0432;<\/li>\n<li>\u043a\u0440\u0443\u0433\u043b\u043e\u0441\u0443\u0442\u043e\u0447\u043d\u043e\u0435 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u043f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043e\u043c \u0434\u0435\u0436\u0443\u0440\u0441\u0442\u0432\u0430 \u0432\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u044b\u0445 \u0441\u043f\u0435\u0446\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043c\u0438 \u043e\u0445\u0440\u0430\u043d\u043d\u0438\u043a\u043e\u0432;<\/li>\n<li>\u0434\u043d\u0435\u0432\u043d\u043e\u0435 \u0438\u043b\u0438 \u043d\u043e\u0447\u043d\u043e\u0435 \u0434\u0435\u0436\u0443\u0440\u0441\u0442\u0432\u043e \u043d\u0435\u0432\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u044b\u0445 \u043e\u0445\u0440\u0430\u043d\u043d\u0438\u043a\u043e\u0432;<\/li>\n<li>\u0434\u043d\u0435\u0432\u043d\u043e\u0435 \u0438\u043b\u0438 \u043d\u043e\u0447\u043d\u043e\u0435 \u0434\u0435\u0436\u0443\u0440\u0441\u0442\u0432\u043e \u0432\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u044b\u0445 \u043e\u0445\u0440\u0430\u043d\u043d\u0438\u043a\u043e\u0432.<\/li>\n<\/ul>\n<h2>\u0412\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u0438\u0435<\/h2>\n<p><img loading=\"lazy\" decoding=\"async\" class=\"alignnone size-full\" src=\"http:\/\/sigma-profi.org\/wp-content\/uploads\/2018\/09\/municipal2.jpg\" alt=\"\" width=\"870\" height=\"400\" \/><\/p>\n<p>\u041d\u0430 \u0432\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u0438\u0438 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432 \u0427\u041e\u041f \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb, \u0440\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e \u043f\u043e\u0432\u044b\u0448\u0430\u044e\u0449\u0438\u0445 \u043a\u0432\u0430\u043b\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0439 \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u043f\u043e \u0432\u0441\u0435\u043c \u0432\u0438\u0434\u0430\u043c \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0438: \u0441\u043b\u0443\u0436\u0435\u0431\u043d\u044b\u0435 \u043f\u0438\u0441\u0442\u043e\u043b\u0435\u0442\u044b \u0418\u0416-71, \u0440\u0443\u0436\u044c\u044f \u0412\u0435\u043f\u0440\u044c-12 \u041c\u043e\u043b\u043e\u0442 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u0441\u043f\u0435\u0446\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430.<\/p>\n<h2>\u0414\u043e\u0441\u0442\u043e\u0438\u043d\u0441\u0442\u0432\u0430 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438<\/h2>\n<p>\u0413\u0440\u0443\u043f\u043f\u0430 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0439 \u00ab\u0421\u0438\u0433\u043c\u0430-\u041f\u0440\u043e\u0444\u0438\u00bb, \u0441\u043e\u0441\u0442\u043e\u044f\u0449\u0430\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u0438\u0437 \u0432\u044b\u0441\u043e\u043a\u043e\u043a\u0432\u0430\u043b\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u043e\u0432, \u0438\u043c\u0435\u0435\u0442 \u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u043e\u043f\u044b\u0442 \u0440\u0430\u0431\u043e\u0442\u044b (\u0431\u043e\u043b\u0435\u0435 15 \u043b\u0435\u0442) \u0432 \u0441\u0444\u0435\u0440\u0435 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044f \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438.<\/p>\n<p>\u041c\u044b \u0432\u0441\u0435\u0433\u0434\u0430 \u0443\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u043c \u043f\u043e\u0436\u0435\u043b\u0430\u043d\u0438\u044f \u043a\u043b\u0438\u0435\u043d\u0442\u043e\u0432, \u0438\u0437\u0443\u0447\u0430\u0435\u043c \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u043a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0442\u043e\u0432, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u043c \u043c\u0438\u0440\u043e\u0432\u043e\u0439 \u043e\u043f\u044b\u0442 \u0438 \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u043c \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0435 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u043e\u0441\u043d\u0430\u0449\u0435\u043d\u0438\u0435. \u042d\u0442\u043e \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u0431\u044b\u0441\u0442\u0440\u043e \u043c\u043e\u0434\u0435\u0440\u043d\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u043f\u043e\u0441\u043e\u0431\u044b \u043e\u0445\u0440\u0430\u043d\u044b \u0438 \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0442\u044c \u043e\u043f\u0442\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u043f\u043e \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044e \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 \u0430\u043f\u0442\u0435\u0447\u043d\u043e\u0433\u043e \u0431\u0438\u0437\u043d\u0435\u0441\u0430.<\/p>\n<p>\n<\/div><\/div><\/div><\/div><\/div><\/div><\/div><\/div><\/section><section class=\"kc-elm kc-css-948406 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><\/div><\/div><\/section><section class=\"kc-elm kc-css-667483 kc_row\"><div class=\"kc-row-container  kc-container\"><div class=\"kc-wrap-columns\"><div class=\"kc-elm kc-css-911473 kc_col-sm-12 kc_column kc_col-sm-12\"><div class=\"kc-col-container\">\n<div class=\"kc-elm kc-css-365379 kc-title-wrap \">\n\n\t<h2 class=\"kc_title\">\u041a\u0430\u043a \u043c\u044b \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u043c<\/h2>\n<\/div>\n<div class=\"kc-elm kc-css-134451 kc_row kc_row_inner\"><div class=\"kc-elm kc-css-924906 kc_col-sm-4 kc_column_inner kc_col-sm-4\"><div class=\"kc_wrapper kc-col-inner-container\"><div class=\"kc-elm kc-css-184126 kc-raw-code\"><div class=\"shagblock\">\r\n\t<div class=\"shagnum\">\r\n\t1\r\n\t<\/div>\r\n\t<div class=\"shagicon\">\r\n\t\t<i class=\"fa fa-phone\" aria-hidden=\"true\"><\/i>\r\n\t<\/div>\r\n\t<div class=\"shagcont\">\r\n\t\t<span>\u041c\u044b \u0432\u0441\u0435\u0433\u0434\u0430 \u043d\u0430 \u0441\u0432\u044f\u0437\u0438<\/span>\r\n\t\t<p>\u041c\u044b \u043d\u0430 \u0441\u0432\u044f\u0437\u0438 24 \u0447\u0430\u0441\u0430 \u0432 \u0441\u0443\u0442\u043a\u0438, 7 \u0434\u043d\u0435\u0439 \u0432 \u043d\u0435\u0434\u0435\u043b\u044e: \u043f\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0443, \