{
  "functions": {
    "api/index.js": {
      "includeFiles": "{public/**,config.json}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "redirects": [
    { "source": "/en",  "destination": "/", "permanent": true },
    { "source": "/en/", "destination": "/", "permanent": true },
    { "source": "/zh",  "destination": "/", "permanent": true },
    { "source": "/zh/", "destination": "/", "permanent": true }
  ]
}
